---
import '../styles/global.css';

const stats = [
  { value: "19", label: "African Languages" },
  { value: "57", label: "Open-Source Models" },
  { value: "26.9pp", label: "Avg. WER Reduction" },
  { value: "2,279h", label: "Training Speech" },
];

const results = [
  { lang: "Acholi",   iso: "ach", family: "Nilo-Saharan",       mms: 42.3, ws: 42.3, wt: 57.7 },
  { lang: "Akan",     iso: "aka", family: "Niger-Congo",         mms: 34.2, ws: 31.7, wt: 37.9 },
  { lang: "Amharic",  iso: "amh", family: "Afro-Asiatic",        mms: 37.8, ws: 33.6, wt: 41.3 },
  { lang: "Dagaare",  iso: "dga", family: "Niger-Congo",         mms: 34.9, ws: 34.0, wt: 37.3 },
  { lang: "Dagbani",  iso: "dag", family: "Niger-Congo",         mms: 35.0, ws: 34.0, wt: 39.5 },
  { lang: "Ewe",      iso: "ewe", family: "Niger-Congo (Kwa)",   mms: 31.3, ws: 32.3, wt: 35.5 },
  { lang: "Fula",     iso: "ful", family: "Atlantic-Congo",      mms: 40.6, ws: 42.6, wt: 46.9 },
  { lang: "Ikposo",   iso: "kpo", family: "Niger-Congo (Kwa)",   mms: 75.3, ws: 77.5, wt: 80.9 },
  { lang: "Lingala",  iso: "lin", family: "Niger-Congo (Bantu)", mms: 42.6, ws: 42.7, wt: 49.0 },
  { lang: "Luganda",  iso: "lug", family: "Niger-Congo (Bantu)", mms: 16.9, ws: 21.6, wt: 33.8 },
  { lang: "Malagasy", iso: "mlg", family: "Austronesian",        mms: 12.8, ws: 13.1, wt: 17.7 },
  { lang: "Masaaba",  iso: "mas", family: "Niger-Congo (Bantu)", mms: 49.5, ws: 75.5, wt: 59.6 },
  { lang: "Nyankole", iso: "nyn", family: "Niger-Congo (Bantu)", mms: 38.6, ws: 44.7, wt: 46.7 },
  { lang: "Oromo",    iso: "orm", family: "Afro-Asiatic",        mms: 26.9, ws: 25.2, wt: 29.3 },
  { lang: "Shona",    iso: "sna", family: "Niger-Congo (Bantu)", mms: 25.0, ws: 26.9, wt: 31.4 },
  { lang: "Sidama",   iso: "sid", family: "Afro-Asiatic",        mms: 35.6, ws: 30.1, wt: 34.4 },
  { lang: "Soga",     iso: "sog", family: "Niger-Congo (Bantu)", mms: 47.2, ws: 57.1, wt: 69.0 },
  { lang: "Tigrinya", iso: "tir", family: "Afro-Asiatic",        mms: 57.1, ws: 53.5, wt: 60.3 },
  { lang: "Wolaytta", iso: "wal", family: "Afro-Asiatic",        mms: 38.8, ws: 39.5, wt: 42.6 },
];

const collections = [
  { name: "MMS-300M",      slug: "waxalnet-mms-300m-6a19b5af3a7ae8c9ef86fd6a",          params: "300M", arch: "CTC",            desc: "Best character-level accuracy. Wins on all 6 Bantu languages. Immune to repetition loops.", color: "from-emerald-500 to-green-600" },
  { name: "Whisper Small", slug: "waxalnet-whisper-small-6a19b5c43a7ae8c9ef87003b", params: "244M", arch: "Autoregressive",  desc: "Preferred for Afro-Asiatic languages. Strong language model prior aids complex morphology.", color: "from-green-500 to-teal-600" },
  { name: "Whisper Tiny",  slug: "waxalnet-whisper-tiny-6a19b5d7447ed909ef134855",  params: "39M",  arch: "Autoregressive",  desc: "Ultra-lightweight edge deployment. Runs on mobile hardware without an internet connection.", color: "from-teal-500 to-green-700" },
];

const authors = [
  "Victor Tolulope Olufemi","Oreoluwa Babatunde","Ramsey Njema","Bolarinwa Gbotemi",
  "Wanchi Lucia Yen","John Uzodinma","Sunday Ajayi","Oluwademilade Williams",
  "Kausar Moshood","Innocent Elendu Anyaele","Akebert Tesfahunegn Arefaine",
  "Candace Hunzwi","Wongel Dawit Daniel","Emmilly Immaculate Namuganga",
  "Cleophas Kadima","Athanase Biluge Bahizire","Onitsiky Ranaivoson","Emmanuel Aaron",
  "Nicholaus Dismas Ladislaus","Idris Muhammed","Jonathan Enoch Simenya","Martin Koome",
  "Matewos Tegete Endaylalu","Peter Ifeoluwa Adeyemo","Hondi Prisca Birindwa",
  "Ukachi Agnes Eze-Mbey","Yacoba Oduro-Yeboah","Toluwani Aremu","Pericles Adjovi",
  "Mikel K Ngueajio","Prasenjit Mitra",
];

const snippet = `from transformers import pipeline

# Replace {language} with any of the 19 ISO codes
# e.g. lug, amh, sna, ewe, orm ...
asr = pipeline("automatic-speech-recognition",
               model="waxal-benchmarking/mms-300m-waxal-{language}")

result = asr("audio.wav")
print(result["text"])`;

const citation = `@article{waxalnet2026,
  title  = {The WAXAL ASR Benchmark: Fine-Tuned Edge Models Across 19 African Languages},
  author = {Olufemi, Victor Tolulope and Babatunde, Oreoluwa and Njema, Ramsey and
            Gbotemi, Bolarinwa and Yen, Wanchi Lucia and Uzodinma, John and
            Ajayi, Sunday and Williams, Oluwademilade and Moshood, Kausar and
            Anyaele, Innocent Elendu and Arefaine, Akebert Tesfahunegn and
            Hunzwi, Candace and Daniel, Wongel Dawit and Namuganga, Emmilly Immaculate and
            Kadima, Cleophas and Bahizire, Athanase Biluge and Ranaivoson, Onitsiky and
            Aaron, Emmanuel and Ladislaus, Nicholaus Dismas and Muhammed, Idris and
            Simenya, Jonathan Enoch and Koome, Martin and Endaylalu, Matewos Tegete and
            Adeyemo, Peter Ifeoluwa and Birindwa, Hondi Prisca and Eze-Mbey, Ukachi Agnes and
            Oduro-Yeboah, Yacoba and Aremu, Toluwani and Adjovi, Pericles and
            Ngueajio, Mikel K and Mitra, Prasenjit},
  year   = {2026},
  note   = {arXiv preprint arXiv:2606.02375}
}`;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>WAXALNet — African ASR Benchmark</title>
  <meta name="description" content="57 open-source ASR models fine-tuned across 19 African languages. Fine-tuned edge models outperform zero-shot giants by 26.9pp." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌍</text></svg>" />
</head>
<body class="dot-pattern">

  <!-- NAV -->
  <nav class="fixed top-0 inset-x-0 z-50 glass border-b border-green-500/10">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <span class="font-bold text-lg" style="font-family:'Plus Jakarta Sans',sans-serif">
        <span class="gradient-text">WAXAL</span><span class="text-green-500/60">net</span>
      </span>
      <div class="hidden md:flex items-center gap-8 text-sm text-green-100/70">
        <a href="#results" class="hover:text-green-400 transition-colors">Results</a>
        <a href="#models"  class="hover:text-green-400 transition-colors">Models</a>
        <a href="#paper"   class="hover:text-green-400 transition-colors">Paper</a>
        <a href="#team"    class="hover:text-green-400 transition-colors">Team</a>
        <a href="https://huggingface.co/waxal-benchmarking" target="_blank"
           class="px-4 py-1.5 rounded-full bg-green-500/15 border border-green-500/30 text-green-400 hover:bg-green-500/25 transition-all text-xs font-medium">
          🤗 HuggingFace
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- Orbs -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="orb-1 absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-20"
           style="background:radial-gradient(circle,#22c55e,transparent 70%);filter:blur(40px)"></div>
      <div class="orb-2 absolute bottom-1/3 right-1/4 w-80 h-80 rounded-full opacity-15"
           style="background:radial-gradient(circle,#16a34a,transparent 70%);filter:blur(50px)"></div>
      <div class="orb-3 absolute top-1/2 right-1/3 w-64 h-64 rounded-full opacity-10"
           style="background:radial-gradient(circle,#4ade80,transparent 70%);filter:blur(60px)"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <!-- Badge -->
      <div class="fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass border border-green-500/20 text-green-400 text-xs font-medium mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
        19 African Languages · 57 Models · Open Source
      </div>

      <!-- Title -->
      <h1 class="fade-in-delay text-5xl md:text-7xl font-extrabold leading-tight tracking-tight mb-6"
          style="font-family:'Plus Jakarta Sans',sans-serif">
        <span class="gradient-text">WAXALNet</span><br/>
        <span class="text-white/90 text-4xl md:text-5xl font-semibold">African ASR Benchmark</span>
      </h1>

      <!-- Subtitle -->
      <p class="fade-in-delay-2 text-lg md:text-xl text-green-100/60 max-w-2xl mx-auto leading-relaxed mb-12">
        57 open-source ASR models fine-tuned across 19 African languages.
        Compact edge models outperform zero-shot giants by <span class="text-green-400 font-semibold">26.9pp WER</span> — using models 3–40× smaller.
      </p>

      <!-- CTAs -->
      <div class="fade-in-delay-2 flex flex-wrap items-center justify-center gap-4">
        <a href="https://arxiv.org/abs/2606.02375" target="_blank"
           class="px-8 py-3.5 rounded-full bg-green-500 hover:bg-green-400 text-black font-semibold text-sm transition-all hover:shadow-lg hover:shadow-green-500/30">
          Read Paper ↗
        </a>
        <a href="https://huggingface.co/waxal-benchmarking" target="_blank"
           class="px-8 py-3.5 rounded-full glass border border-green-500/30 hover:border-green-500/60 text-green-300 font-semibold text-sm transition-all">
          🤗 Browse Models
        </a>
        <a href="#results"
           class="px-8 py-3.5 rounded-full text-green-400/70 hover:text-green-400 font-semibold text-sm transition-colors">
          View Results ↓
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-green-500/40 text-xs">
      <span>scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-green-500/40 to-transparent"></div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-20 relative">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((s, i) => (
          <div class="reveal glass rounded-2xl p-6 text-center" style={`transition-delay:${i*80}ms`}>
            <div class="text-4xl md:text-5xl font-extrabold gradient-text mb-2"
                 style="font-family:'Plus Jakarta Sans',sans-serif">{s.value}</div>
            <div class="text-green-100/50 text-sm">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PAPER -->
  <section id="paper" class="py-24 relative">
    <div class="section-divider mb-24"></div>
    <div class="max-w-4xl mx-auto px-6">
      <div class="reveal text-center mb-12">
        <span class="text-green-500 text-xs font-semibold uppercase tracking-widest mb-3 block">Publication</span>
        <h2 class="text-3xl md:text-4xl font-bold" style="font-family:'Plus Jakarta Sans',sans-serif">The Paper</h2>
      </div>
      <div class="reveal glass rounded-3xl p-8 md:p-12">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center flex-shrink-0 mt-1">
            <span class="text-lg">📄</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white mb-1" style="font-family:'Plus Jakarta Sans',sans-serif">
              The WAXAL ASR Benchmark: Fine-Tuned Edge Models Across 19 African Languages
            </h3>
            <p class="text-green-400/60 text-sm">2026 · <a href="https://arxiv.org/abs/2606.02375" target="_blank" class="underline hover:text-green-400 transition-colors">arXiv:2606.02375</a></p>
          </div>
        </div>
        <p class="text-green-100/65 leading-relaxed mb-8">
          We benchmark three zero-shot foundation models against compact fine-tuned edge models across 19 African languages
          using the conversational WAXAL corpus. Fine-tuned edge models achieve a macro-averaged WER of <strong class="text-green-400">38.0%</strong> compared
          to <strong class="text-green-300">64.9%</strong> for the best zero-shot baseline — a 26.9pp reduction using models 3–40× smaller.
          An audit by native speakers across all 19 languages reveals systematic architectural failure patterns aligned with language
          family, script system, and morphological typology.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="https://arxiv.org/abs/2606.02375" target="_blank" class="px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs hover:bg-green-500/20 transition-colors">arXiv:2606.02375 ↗</a>
          <span class="px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs">CC-BY 4.0 Data</span>
          <span class="px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs">Open-Source Models</span>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTS -->
  <section id="results" class="py-24 relative">
    <div class="section-divider mb-24"></div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-12">
        <span class="text-green-500 text-xs font-semibold uppercase tracking-widest mb-3 block">Benchmark</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family:'Plus Jakarta Sans',sans-serif">Results</h2>
        <p class="text-green-100/50 max-w-xl mx-auto">Word Error Rate (%) on the WAXAL test set. Lower is better.</p>
      </div>
      <div class="reveal glass rounded-3xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full results-table">
            <thead>
              <tr class="border-b border-green-500/15">
                <th class="text-left px-6 py-4 text-green-400 text-xs font-semibold uppercase tracking-wider">Language</th>
                <th class="text-left px-4 py-4 text-green-400/60 text-xs font-semibold uppercase tracking-wider">Family</th>
                <th class="text-center px-4 py-4 text-green-400 text-xs font-semibold uppercase tracking-wider">MMS-300M</th>
                <th class="text-center px-4 py-4 text-green-300/80 text-xs font-semibold uppercase tracking-wider">Whisper S</th>
                <th class="text-center px-4 py-4 text-green-300/60 text-xs font-semibold uppercase tracking-wider">Whisper T</th>
              </tr>
            </thead>
            <tbody>
              {results.map((r) => {
                const best = Math.min(r.mms, r.ws, r.wt);
                return (
                  <tr class="border-b border-green-500/8 transition-colors">
                    <td class="px-6 py-3.5 font-medium text-white/90 text-sm">{r.lang}</td>
                    <td class="px-4 py-3.5 text-green-100/40 text-xs">{r.family}</td>
                    <td class={`px-4 py-3.5 text-center text-sm font-mono ${r.mms === best ? 'text-green-400 font-bold' : 'text-green-100/60'}`}>{r.mms}</td>
                    <td class={`px-4 py-3.5 text-center text-sm font-mono ${r.ws === best ? 'text-green-400 font-bold' : 'text-green-100/60'}`}>{r.ws}</td>
                    <td class={`px-4 py-3.5 text-center text-sm font-mono ${r.wt === best ? 'text-green-400 font-bold' : 'text-green-100/60'}`}>{r.wt}</td>
                  </tr>
                );
              })}
            </tbody>
            <tfoot>
              <tr class="border-t border-green-500/20 bg-green-500/5">
                <td class="px-6 py-4 font-bold text-white text-sm">Macro Average</td>
                <td class="px-4 py-4"></td>
                <td class="px-4 py-4 text-center text-green-400 font-bold text-sm font-mono">38.0</td>
                <td class="px-4 py-4 text-center text-green-300/80 font-bold text-sm font-mono">39.9</td>
                <td class="px-4 py-4 text-center text-green-300/60 font-bold text-sm font-mono">44.2</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
      <p class="text-center text-green-100/30 text-xs mt-4">Bold = best fine-tuned model per language</p>
    </div>
  </section>

  <!-- MODELS -->
  <section id="models" class="py-24 relative">
    <div class="section-divider mb-24"></div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-12">
        <span class="text-green-500 text-xs font-semibold uppercase tracking-widest mb-3 block">Open Source</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family:'Plus Jakarta Sans',sans-serif">WAXALNet Models</h2>
        <p class="text-green-100/50 max-w-xl mx-auto">Three model families, 19 languages each. All available on HuggingFace.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {collections.map((c, i) => (
          <a href={`https://huggingface.co/collections/waxal-benchmarking/${c.slug}`} target="_blank"
             class={`reveal glass rounded-3xl p-8 hover:border-green-500/40 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-green-500/10 group block`}
             style={`transition-delay:${i*80}ms`}>
            <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${c.color} flex items-center justify-center mb-6 text-white font-bold text-lg group-hover:scale-110 transition-transform`}>
              🎙
            </div>
            <div class="text-green-400/50 text-xs font-mono mb-1">{c.params} · {c.arch}</div>
            <h3 class="text-xl font-bold text-white mb-3" style="font-family:'Plus Jakarta Sans',sans-serif">{c.name}</h3>
            <p class="text-green-100/55 text-sm leading-relaxed mb-6">{c.desc}</p>
            <div class="flex items-center gap-2 text-green-400 text-xs font-medium">
              <span>19 languages</span>
              <span class="text-green-500/30">·</span>
              <span>View on HuggingFace →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Usage snippet -->
      <div class="reveal mt-12 glass rounded-3xl p-8">
        <div class="flex items-center justify-between mb-4">
          <span class="text-green-400 text-sm font-semibold">Quick Start</span>
          <button id="copy-btn" class="text-xs text-green-500/60 hover:text-green-400 transition-colors px-3 py-1 rounded-lg border border-green-500/20 hover:border-green-500/40">
            Copy
          </button>
        </div>
        <pre class="code-block text-green-300/80 overflow-x-auto"><code id="code-snippet" set:text={snippet} /></pre>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-24 relative">
    <div class="section-divider mb-24"></div>
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal text-center mb-12">
        <span class="text-green-500 text-xs font-semibold uppercase tracking-widest mb-3 block">People</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family:'Plus Jakarta Sans',sans-serif">The Team</h2>
        <p class="text-green-100/50">31 researchers across 3 continents</p>
      </div>
      <div class="reveal glass rounded-3xl p-8 md:p-10 mb-8">
        <div class="flex flex-wrap gap-x-2 gap-y-3">
          {authors.map((a, i) => (
            <span class="text-green-100/80 text-sm">
              {a}{i < authors.length - 1 ? <span class="text-green-500/30 mx-1">·</span> : ''}
            </span>
          ))}
        </div>
      </div>

      <!-- Orgs -->
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { name: "LyngualLabs", url: "https://lynguallabs.org/",  role: "Compute · Researchers · Storage", emoji: "🧪", red: false },
          { name: "Open Token",  url: "https://opentoken.global/", role: "Compute Resources",                emoji: "⚡", red: false },
          { name: "Carnegie Mellon University Africa", url: "https://www.africa.engineering.cmu.edu/", role: "Researchers · Native Speakers", emoji: "🎓", red: true },
        ].map((org, i) => (
          <a href={org.url} target="_blank"
             class={`reveal rounded-2xl p-6 transition-all hover:-translate-y-0.5 group block ${org.red ? 'bg-red-950/60 border border-red-700/30 hover:border-red-500/60' : 'glass hover:border-green-500/40'}`}
             style={`transition-delay:${i*80}ms`}>
            <div class="text-2xl mb-3">{org.emoji}</div>
            <div class={`font-semibold mb-1 transition-colors ${org.red ? 'text-red-300 group-hover:text-red-200' : 'text-white group-hover:text-green-400'}`}>{org.name}</div>
            <div class={`text-xs ${org.red ? 'text-red-300/50' : 'text-green-100/40'}`}>{org.role}</div>
          </a>
        ))}
      </div>

      <!-- Acknowledgements -->
      <div class="reveal mt-4 glass rounded-2xl p-6">
        <p class="text-green-100/50 text-sm leading-relaxed">
          <span class="text-green-400 font-medium">Linguistic Acknowledgements: </span>
          Ajara Oyinloye · Abubakari Sadic Mohammed · Hafiz Adjei · Aliga Norah Lele · Marie-Louise B. Ndamuso · Odong Diana
        </p>
      </div>
    </div>
  </section>

  <!-- CITATION -->
  <section class="py-24 relative">
    <div class="section-divider mb-24"></div>
    <div class="max-w-3xl mx-auto px-6">
      <div class="reveal text-center mb-10">
        <span class="text-green-500 text-xs font-semibold uppercase tracking-widest mb-3 block">Reference</span>
        <h2 class="text-3xl font-bold" style="font-family:'Plus Jakarta Sans',sans-serif">Cite this work</h2>
      </div>
      <div class="reveal glass rounded-3xl p-8">
        <div class="flex items-center justify-between mb-4">
          <span class="text-green-400/60 text-xs font-mono">BibTeX</span>
          <button id="copy-cite-btn" class="text-xs text-green-500/60 hover:text-green-400 transition-colors px-3 py-1 rounded-lg border border-green-500/20 hover:border-green-500/40">
            Copy Citation
          </button>
        </div>
        <pre class="code-block text-green-300/70 overflow-x-auto whitespace-pre-wrap" id="citation-block" set:text={citation} /></pre>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-green-500/10 py-10">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-green-100/30 text-sm">
        © 2026 WAXAL Benchmarking Team · CC-BY 4.0
      </div>
      <div class="flex items-center gap-6 text-sm text-green-100/40">
        <a href="https://huggingface.co/waxal-benchmarking" target="_blank" class="hover:text-green-400 transition-colors">HuggingFace</a>
        <span class="text-green-500/20">·</span>
        <a href="https://lynguallabs.org/" target="_blank" class="hover:text-green-400 transition-colors">LyngualLabs</a>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  // Reveal on scroll
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Copy code snippet
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const code = document.getElementById('code-snippet')?.textContent || '';
    navigator.clipboard.writeText(code);
    const btn = document.getElementById('copy-btn');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); }
  });

  // Copy citation
  document.getElementById('copy-cite-btn')?.addEventListener('click', () => {
    const cite = document.getElementById('citation-block')?.textContent || '';
    navigator.clipboard.writeText(cite);
    const btn = document.getElementById('copy-cite-btn');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy Citation', 2000); }
  });
</script>
